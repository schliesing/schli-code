# --- Ferramentas ---
def create_tools(llm=None) -> list:
    tools = []

{% for skill in skills if skill.enabled %}
{% if skill.id == "web_search" %}
    from langchain_community.tools import DuckDuckGoSearchRun
    search = DuckDuckGoSearchRun()
    tools.append(Tool(
        name="busca_web",
        func=search.run,
        description=(
            "Útil para buscar informações atualizadas na internet. "
            "Use quando precisar de notícias recentes ou fatos atuais. "
            "Input: uma pergunta ou termo de busca."
        ),
    ))

{% elif skill.id == "code_execution" %}
    from langchain_community.tools.python.tool import PythonREPLTool
    repl = PythonREPLTool()
    tools.append(Tool(
        name="executar_codigo_python",
        func=repl.run,
        description=(
            "Executa código Python e retorna o resultado. "
            "Input: código Python válido como string."
        ),
    ))

{% elif skill.id == "file_read" %}
    def read_file(path: str) -> str:
        try:
            with open(path, "r", encoding="utf-8") as f:
                content = f.read()
            return content[:10000] + ("\n... [truncado]" if len(content) > 10000 else "")
        except Exception as e:
            return f"Erro ao ler arquivo: {e}"

    tools.append(Tool(
        name="ler_arquivo",
        func=read_file,
        description="Lê o conteúdo de um arquivo de texto. Input: caminho para o arquivo.",
    ))

{% elif skill.id == "calculator" %}
    import math

    def calculate(expression: str) -> str:
        try:
            allowed = {k: v for k, v in math.__dict__.items() if not k.startswith("__")}
            allowed.update({"abs": abs, "round": round})
            return str(eval(expression, {"__builtins__": {}}, allowed))
        except Exception as e:
            return f"Erro no cálculo: {e}"

    tools.append(Tool(
        name="calculadora",
        func=calculate,
        description="Realiza operações matemáticas. Input: expressão matemática (ex: '2 + 2', 'sqrt(16)').",
    ))

{% elif skill.id == "datetime" %}
    def get_datetime(query: str = "") -> str:
        now = datetime.now(timezone.utc)
        days = ["Segunda-feira", "Terça-feira", "Quarta-feira", "Quinta-feira", "Sexta-feira", "Sábado", "Domingo"]
        return (
            f"Data e hora atual (UTC): {now.strftime('%d/%m/%Y %H:%M:%S')}\n"
            f"Dia da semana: {days[now.weekday()]}"
        )

    tools.append(Tool(
        name="data_hora_atual",
        func=get_datetime,
        description="Retorna a data e hora atual. Input: qualquer string.",
    ))

{% elif skill.id == "email" %}
    import smtplib
    import json as _json
    from email.mime.text import MIMEText

    def send_email(input_str: str) -> str:
        try:
            data = _json.loads(input_str)
        except Exception:
            return "Erro: input deve ser JSON com campos 'to', 'subject', 'body'."
        smtp_host = "{{ skill.config.get('smtp_host', 'smtp.gmail.com') }}"
        smtp_port = {{ skill.config.get('smtp_port', 587) }}
        smtp_user = "{{ skill.config.get('smtp_user', '') }}"
        smtp_pass = os.environ.get("{{ skill.config.get('smtp_password_env', 'EMAIL_PASSWORD') }}", "")
        try:
            msg = MIMEText(data.get("body", ""), "plain", "utf-8")
            msg["Subject"] = data.get("subject", "Sem assunto")
            msg["From"] = smtp_user
            msg["To"] = data.get("to", "")
            with smtplib.SMTP(smtp_host, smtp_port) as s:
                s.starttls()
                s.login(smtp_user, smtp_pass)
                s.sendmail(smtp_user, [data["to"]], msg.as_string())
            return f"Email enviado para {data['to']}."
        except Exception as e:
            return f"Erro ao enviar email: {e}"

    tools.append(Tool(
        name="enviar_email",
        func=send_email,
        description='Envia um email. Input: JSON {"to": "...", "subject": "...", "body": "..."}',
    ))

{% endif %}
{% endfor %}

    return tools


# --- Memória ---
def create_memory(llm=None):
{% if not memory or memory.type == "none" %}
    return None
{% elif memory.type == "simple" %}
    return ConversationBufferMemory(
        memory_key="chat_history",
        return_messages=True,
        output_key="output",
    )
{% elif memory.type == "semantic" %}
    return ConversationSummaryMemory(
        llm=llm,
        memory_key="chat_history",
        return_messages=True,
        output_key="output",
    )
{% elif memory.type == "vector_rag" %}
    from langchain_community.vectorstores import Chroma
    from langchain_openai import OpenAIEmbeddings
    embeddings = OpenAIEmbeddings(api_key=os.environ.get("OPENAI_API_KEY", ""))
    vectorstore = Chroma(
        collection_name="agent_memory",
        embedding_function=embeddings,
        persist_directory="./chroma_db",
    )
    retriever = vectorstore.as_retriever(search_kwargs={"k": 4})
    return VectorStoreRetrieverMemory(retriever=retriever)
{% else %}
    return ConversationBufferMemory(
        memory_key="chat_history",
        return_messages=True,
        output_key="output",
    )
{% endif %}


# --- Prompt ---
SYSTEM_PROMPT = """{{ persona.system_prompt if persona else "Você é um assistente de IA útil." }}

Responda sempre em português brasileiro, a menos que o usuário escreva em outro idioma."""

REACT_TEMPLATE = SYSTEM_PROMPT + """

Você tem acesso às seguintes ferramentas:

{tools}

Use o seguinte formato:

Question: a pergunta de entrada
Thought: pense sobre o que fazer
Action: a ação a tomar (uma de [{tool_names}])
Action Input: a entrada para a ação
Observation: o resultado da ação
... (repita Thought/Action/Action Input/Observation até ter a resposta)
Thought: agora eu sei a resposta final
Final Answer: a resposta final

Histórico:
{chat_history}

Question: {input}
{agent_scratchpad}"""


# --- Fábrica do Agente ---
def create_agent() -> AgentExecutor:
    llm = create_llm()
    tools = create_tools(llm)
    memory = create_memory(llm)
    prompt = PromptTemplate.from_template(REACT_TEMPLATE)

    agent = create_react_agent(llm=llm, tools=tools, prompt=prompt)

    kwargs: dict = {
        "agent": agent,
        "tools": tools,
        "verbose": True,
        "handle_parsing_errors": True,
        "max_iterations": 10,
    }
    if memory is not None:
        kwargs["memory"] = memory

    return AgentExecutor(**kwargs)


if __name__ == "__main__":
    agent = create_agent()
    print("{{ persona.greeting if persona else 'Olá! Como posso ajudar?' }}")
    while True:
        user_input = input("\nVocê: ").strip()
        if user_input.lower() in ("sair", "exit", "quit"):
            print("Até logo!")
            break
        if not user_input:
            continue
        result = agent.invoke({"input": user_input})
        print(f"\n{{ persona.name if persona else 'Agente' }}: {result['output']}")
