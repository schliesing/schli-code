def create_llm():
    api_key = os.environ.get("{{ model.api_key_env }}", "")
    if not api_key:
        raise ValueError(
            "Chave de API não encontrada. "
            "Configure a variável de ambiente {{ model.api_key_env }} no arquivo .env"
        )
    return ChatOpenAI(
        model="{{ model.model_id }}",
        temperature={{ model.temperature }},
        max_tokens={{ model.max_tokens }},
        api_key=api_key,
        streaming=True,
    )

