# =============================================================================
# Configurações do {{ persona.name if persona else "Agente IA" }}
# IMPORTANTE: Copie este arquivo para .env e preencha os valores
# =============================================================================

# -----------------------------------------------
# Chaves de API do Modelo de IA
# -----------------------------------------------
{% if model and model.provider == "openai" %}
# OpenAI API Key
# Como obter: https://platform.openai.com/api-keys
# Criar conta em platform.openai.com, ir em API Keys e criar uma nova chave
OPENAI_API_KEY=sk-sua-chave-aqui

{% elif model and model.provider == "anthropic" %}
# Anthropic API Key (Claude)
# Como obter: https://console.anthropic.com/
# Criar conta em console.anthropic.com, ir em API Keys e criar uma nova chave
ANTHROPIC_API_KEY=sk-ant-sua-chave-aqui

{% elif model and model.provider == "gemini" %}
# Google Gemini API Key
# Como obter: https://aistudio.google.com/app/apikey
# Criar conta no Google AI Studio e gerar uma chave (tem plano gratuito!)
GOOGLE_API_KEY=sua-chave-aqui

{% elif model and model.provider == "ollama" %}
# Ollama roda localmente — sem chave de API necessária!
# Certifique-se que o Ollama está instalado: https://ollama.com/download
# Baixe o modelo com: ollama pull {{ model.model_id }}
OLLAMA_BASE_URL=http://localhost:11434

{% elif model and model.provider == "lmstudio" %}
# LM Studio roda localmente — sem chave de API necessária!
# Certifique-se que o LM Studio está aberto e com um modelo carregado
# Habilite o servidor local em: LM Studio > Server > Start Server
LMSTUDIO_BASE_URL=http://localhost:1234/v1

{% endif %}

# -----------------------------------------------
# Configurações de Deploy
# -----------------------------------------------
{% if deployment and "telegram" in deployment.targets %}
# Token do Bot do Telegram
# Como obter:
# 1. Abra o Telegram e procure @BotFather
# 2. Envie: /newbot
# 3. Siga as instruções e copie o token gerado
TELEGRAM_BOT_TOKEN=seu-token-aqui

{% endif %}
{% if deployment and "discord" in deployment.targets %}
# Token do Bot do Discord
# Como obter:
# 1. Acesse discord.com/developers/applications
# 2. Crie uma nova aplicação
# 3. Vá em "Bot" e copie o Token
DISCORD_BOT_TOKEN=seu-token-aqui

{% endif %}
{% if deployment and "whatsapp" in deployment.targets %}
# Credenciais do Twilio para WhatsApp
# Como obter: https://www.twilio.com/
TWILIO_ACCOUNT_SID=seu-sid-aqui
TWILIO_AUTH_TOKEN=seu-token-aqui
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

{% endif %}

# -----------------------------------------------
# Habilidades com Configuração
# -----------------------------------------------
{% for skill in skills if skill.enabled and skill.id == "email" %}
# Configurações de Email (SMTP)
EMAIL_FROM={{ skill.config.get("smtp_user", "seu@email.com") }}
EMAIL_PASSWORD=sua-senha-ou-senha-de-app-aqui
# Para Gmail: use uma "Senha de App" (não sua senha normal)
# Configurar em: myaccount.google.com/apppasswords

{% endfor %}

# -----------------------------------------------
# Configurações Gerais (opcional)
# -----------------------------------------------
# Nível de log: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Fuso horário
TZ=America/Sao_Paulo
